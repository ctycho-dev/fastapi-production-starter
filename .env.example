BASE_URL=http://localhost:8000
ADMIN_LOGIN=admin@dssl.ru
ADMIN_PWD=123456

# Postgres
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=analyser_db
DATABASE_URL=postgresql+asyncpg://root:password@localhost:5432/analyser_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
