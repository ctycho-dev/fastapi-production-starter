# Oauth2
SECRET_KEY=password
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Yandex S3
S3_BUCKET=bucket
S3_ENDPOINT=https://storage.yandexcloud.net
AWS_REGION=ru-central1
